VITE_API_URL=http://localhost:5050/api
# Clinic UUID that owns this patient portal (so signed-up patients appear in the admin Patients page)
VITE_CLINIC_ID=clinic-local-001
# Agent service URL for the patient health assistant chat
VITE_AGENT_API_URL=http://localhost:4000/api
# Google Sign-In client ID (from Google Cloud Console > APIs & Services > Credentials)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
